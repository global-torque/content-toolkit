{
  "name": "@global-torque/content-toolkit",
  "private": false,
  "version": "0.2.0-beta.7",
  "description": "Immutable content records, trees, paths, ordering, and host-configured image srcsets.",
  "keywords": [
    "content",
    "static-site",
    "typescript",
    "url"
  ],
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "sideEffects": false,
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "lint": "eslint --max-warnings=0 src scripts vitest.config.ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.mjs\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"scripts/**/*.mjs\" \".github/**/*.{yml,json,md}\" \"docs/{rfcs,ossf}/**/*.md\" \"*.{json,md,yaml}\"",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "api:check": "api-extractor run --verbose",
    "api:report:update": "pnpm run build && api-extractor run --local --verbose",
    "docs:api": "pnpm run api:report:update && api-documenter markdown --input temp --output docs/api",
    "package:lint": "publint && attw --pack . --profile esm-only",
    "content:check": "node scripts/verify-public-content.mjs",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run test:coverage && pnpm run build && pnpm run api:check && pnpm run package:lint && pnpm run content:check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-documenter": "7.30.7",
    "@microsoft/api-extractor": "7.58.9",
    "@arethetypeswrong/cli": "0.18.5",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "typescript": "^7.0.2",
    "vitest": "4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/global-torque/content-toolkit.git"
  },
  "homepage": "https://github.com/global-torque/content-toolkit#readme",
  "bugs": {
    "url": "https://github.com/global-torque/content-toolkit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE.md",
    "CHANGELOG.md",
    "docs/api",
    "etc/content-toolkit.api.md",
    "SECURITY.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./allData": {
      "types": "./dist/allData.d.ts",
      "import": "./dist/allData.js"
    },
    "./image-srcset": {
      "types": "./dist/imageSrcset.d.ts",
      "import": "./dist/imageSrcset.js"
    },
    "./pageData": {
      "types": "./dist/pageData.d.ts",
      "import": "./dist/pageData.js"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "import": "./dist/pages.js"
    },
    "./url": {
      "types": "./dist/url.d.ts",
      "import": "./dist/url.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  }
}
